---
import Page from '~/layouts/Page.astro';
---

<Page title="404 — Not found" locale="en">
  <section class="max-w-3xl mx-auto px-6 md:px-10 pt-32 pb-40 text-center">
    <p class="stamp text-clinic-red">Error 404</p>
    <h1 class="display-serif mt-3 text-[clamp(5rem,12vw,10rem)] leading-none text-ink italic font-black tracking-[-0.04em]">not<br/>found.</h1>
    <p class="mt-8 text-lead text-ink-600 max-w-prose-wide mx-auto">
      The page you were looking for has been moved or never existed.
      Nothing has been broken. Return to the
      <a href="/datasus-etl/" class="prose-editorial">home page</a>.
    </p>
  </section>
</Page>
