---
import Page from '~/layouts/Page.astro';
---

<Page title="404 — Not found" locale="en">
  <section class="max-w-3xl mx-auto px-6 md:px-10 pt-32 pb-40 text-center">
    <div class="flex items-center justify-center gap-3 text-muted">
      <span class="pill pill-warn"><span class="pill-dot"></span>Error</span>
      <span class="pill pill-mono">404</span>
    </div>
    <h1 class="mt-8 font-mono text-[clamp(4rem,14vw,9rem)] leading-none text-text font-semibold tracking-tight">
      404
    </h1>
    <p class="mt-3 label-stamp-strong text-brand">not found</p>
    <p class="mt-6 text-lead text-muted max-w-prose-tech mx-auto leading-relaxed">
      The page you were looking for has been moved or never existed.
      Nothing has been broken. Return to the
      <a href="/datasus-etl/" class="text-brand hover:text-brand-hover border-b border-brand/40 hover:border-brand-hover">home page</a>.
    </p>
  </section>
</Page>
