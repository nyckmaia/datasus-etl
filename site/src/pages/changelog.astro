---
import Page from '~/layouts/Page.astro';
import { readFileSync, existsSync } from 'node:fs';
import { resolve, dirname } from 'node:path';
import { fileURLToPath } from 'node:url';
import { releasesIndexUrl } from '~/lib/releases';

const HERE = dirname(fileURLToPath(import.meta.url));
const ROOT = resolve(HERE, '..', '..', '..');
const changelogPath = resolve(ROOT, 'CHANGELOG.md');

let markdown = '';
let hasChangelog = false;
if (existsSync(changelogPath)) {
  markdown = readFileSync(changelogPath, 'utf8');
  hasChangelog = markdown.replace(/^#\s+Changelog\s*/, '').trim().length > 0;
}

function renderMarkdown(src: string): string {
  // Small markdown subset renderer — the changelog uses a predictable
  // shape (## / ### / - / **bold** / `code`). No need to pull in a
  // full parser and expand the site's bundle.
  const esc = (s: string) =>
    s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

  const lines = src.replace(/^#\s+Changelog\s*/, '').split('\n');
  const out: string[] = [];
  let listOpen = false;

  const closeList = () => {
    if (listOpen) {
      out.push('</ul>');
      listOpen = false;
    }
  };

  const inline = (text: string) =>
    esc(text)
      .replace(/`([^`]+)`/g, '<code>$1</code>')
      .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');

  for (const raw of lines) {
    const line = raw.trimEnd();
    if (!line) {
      closeList();
      continue;
    }
    let m: RegExpMatchArray | null;
    if ((m = line.match(/^##\s+\[?(.+?)\]?\s*-\s*(.+)$/))) {
      closeList();
      out.push(
        `<section class="changelog-entry"><header><span class="pill pill-brand"><span class="pill-dot"></span>Release</span><h2 class="mono-val text-display text-text">v${esc(m[1])}</h2><time class="mono-val text-sm text-muted">${esc(m[2])}</time></header>`,
      );
      continue;
    }
    if ((m = line.match(/^##\s+(.+)$/))) {
      closeList();
      out.push(`</section><section class="changelog-entry"><header><h2 class="text-display text-text font-semibold">${inline(m[1])}</h2></header>`);
      continue;
    }
    if ((m = line.match(/^###\s+(.+)$/))) {
      closeList();
      out.push(`<h3 class="label-stamp-strong mt-6 text-brand">${inline(m[1])}</h3>`);
      continue;
    }
    if ((m = line.match(/^-\s+(.+)$/))) {
      if (!listOpen) {
        out.push('<ul class="changelog-list">');
        listOpen = true;
      }
      out.push(`<li>${inline(m[1])}</li>`);
      continue;
    }
    closeList();
    out.push(`<p class="text-text max-w-prose-tech">${inline(line)}</p>`);
  }
  closeList();
  // Close any still-open section.
  if (out.some((chunk) => chunk.startsWith('<section'))) {
    out.push('</section>');
  }
  return out.join('\n');
}

const html = hasChangelog ? renderMarkdown(markdown) : '';
---

<Page
  title="Changelog — DataSUS ETL"
  description="Release history, grouped by type, generated from Conventional Commits."
  locale="en"
  currentKey="changelog"
>
  <section class="max-w-5xl mx-auto px-6 md:px-10 pt-16 md:pt-24 pb-24">
    <div class="flex items-center gap-3 text-muted">
      <span class="pill pill-brand"><span class="pill-dot"></span>Changelog</span>
    </div>
    <h1 class="mt-5 text-display-lg text-text font-semibold">Release history.</h1>
    <p class="mt-4 text-lead text-muted max-w-prose-tech leading-relaxed">
      Generated automatically from
      <a href="https://www.conventionalcommits.org/" class="text-brand hover:text-brand-hover border-b border-brand/40 hover:border-brand-hover">Conventional Commits</a>
      at each release. Items are grouped into Added, Fixed, Changed,
      Performance, Documentation, and Other.
    </p>

    {hasChangelog ? (
      <div class="mt-10 changelog" set:html={html} />
    ) : (
      <div class="mt-12 card p-10 text-center">
        <div class="label-stamp text-muted">Empty log</div>
        <p class="mt-3 text-display text-text font-semibold">No releases yet.</p>
        <p class="mt-3 text-sm text-muted max-w-prose-tech mx-auto">
          This page will populate automatically when the first versioned
          release is published. In the meantime, follow development on the
          <a href={releasesIndexUrl()} class="text-brand hover:text-brand-hover border-b border-brand/40 hover:border-brand-hover">GitHub releases page</a>.
        </p>
      </div>
    )}
  </section>
</Page>

<style is:global>
  .changelog-entry {
    padding-top: 2rem;
    padding-bottom: 1.5rem;
    border-top: 1px solid rgb(var(--border));
  }
  .changelog-entry:first-of-type {
    border-top: 2px solid rgb(var(--brand));
  }
  .changelog-entry header {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 1rem;
    align-items: baseline;
    margin-bottom: 0.75rem;
  }
  .changelog-list {
    margin-top: 0.5rem;
    padding-left: 1.2rem;
    list-style: disc;
  }
  .changelog-list li {
    padding-left: 0.25rem;
    margin-top: 0.3rem;
    max-width: 72ch;
    line-height: 1.55;
    color: rgb(var(--text));
  }
  .changelog-list li::marker {
    color: rgb(var(--brand));
  }
  .changelog code {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.86em;
    background: rgb(var(--surface-2));
    border: 1px solid rgb(var(--border));
    padding: 0.08em 0.35em;
    border-radius: 3px;
    color: rgb(var(--text));
  }
</style>
