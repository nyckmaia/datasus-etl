---
import Page from '~/layouts/Page.astro';

const EMAIL = 'nyckmaia@gmail.com';
---

<Page
  title="Contact Us"
  description="Suggestions, questions, and critique are welcome — drop us an email."
  locale="en"
  currentKey="contact"
  ptPath="/contact"
>
  <section class="max-w-3xl mx-auto px-6 md:px-10 pt-16 md:pt-24 pb-28">
    <div class="flex items-center gap-3 text-muted">
      <span class="pill pill-brand"><span class="pill-dot"></span>Contact</span>
    </div>
    <h1 class="mt-5 text-display-lg text-text font-semibold">Get in touch.</h1>
    <p class="mt-4 text-lead text-muted max-w-[60ch] leading-relaxed">
      Improvement suggestions, questions, and critique are all welcome.
      Send a message directly to the email below.
    </p>

    <div class="mt-10 card p-6 max-w-xl">
      <div class="label-stamp text-brand">Email</div>
      <div class="mt-3 flex flex-wrap items-center gap-3">
        <a
          href={`mailto:${EMAIL}`}
          class="font-mono text-lg text-text underline-offset-4 hover:underline"
        >
          {EMAIL}
        </a>
      </div>
      <p class="mt-4 text-sm text-muted">
        Click the address to open it in your default mail app, or copy and
        paste it into your preferred client.
      </p>
    </div>
  </section>
</Page>
