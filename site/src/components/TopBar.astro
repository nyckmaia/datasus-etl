---
import LanguageToggle from './LanguageToggle.astro';
import { NAV, localePath, type Locale } from '~/lib/i18n';
import { repoUrl } from '~/lib/releases';

interface Props {
  locale: Locale;
  currentKey?: string;
  ptPath?: string;
}

const { locale, currentKey, ptPath } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<header class="relative z-40">
  <div class="max-w-7xl mx-auto px-6 md:px-10 pt-6 pb-3">
    <div class="flex items-end justify-between gap-6">
      <a href={localePath(locale, '/', base)} class="flex items-end gap-3 group">
        <span
          class="display-serif leading-none text-[2rem] md:text-[2.4rem] font-black text-ink tracking-[-0.035em]"
        >DATASUS<span class="text-clinic-red">·</span>ETL</span>
        <span class="stamp text-ink-400 pb-1 hidden md:inline">
          {locale === 'pt' ? 'Dados públicos de saúde' : 'Brazilian public-health data'}
        </span>
      </a>

      <nav class="hidden md:flex items-center gap-6 stamp text-ink-600">
        {NAV.map((item) => {
          const href = item.path[locale] ?? item.path.en;
          const target = `${base}${href}`.replace(/\/+/g, '/');
          const active = currentKey === item.key;
          return (
            <a
              href={target}
              class:list={[
                'relative pb-1 hover:text-ink transition-colors',
                active && 'text-ink',
              ]}
              aria-current={active ? 'page' : undefined}
            >
              {item.labels[locale]}
              {active && <span class="absolute inset-x-0 -bottom-[2px] h-[2px] bg-clinic-red"></span>}
            </a>
          );
        })}
        <a
          href={repoUrl()}
          rel="noopener noreferrer"
          target="_blank"
          class="hover:text-ink"
          aria-label="GitHub repository"
        >
          GitHub <span aria-hidden="true">↗</span>
        </a>
        <LanguageToggle current={locale} ptPath={ptPath} base={base} />
      </nav>

      <!-- Mobile compact: only lang + GH -->
      <div class="md:hidden flex items-center gap-3">
        <a href={repoUrl()} rel="noopener noreferrer" target="_blank" class="stamp text-ink-600">GH</a>
        <LanguageToggle current={locale} ptPath={ptPath} base={base} />
      </div>
    </div>

    <!-- Mobile nav row -->
    <nav class="md:hidden mt-4 flex flex-wrap gap-x-4 gap-y-2 stamp text-ink-600">
      {NAV.map((item) => {
        const href = item.path[locale] ?? item.path.en;
        const target = `${base}${href}`.replace(/\/+/g, '/');
        const active = currentKey === item.key;
        return (
          <a
            href={target}
            class:list={['pb-1', active ? 'text-ink border-b-2 border-clinic-red' : '']}
          >
            {item.labels[locale]}
          </a>
        );
      })}
    </nav>
  </div>
  <div class="hairline max-w-7xl mx-auto"></div>
</header>
