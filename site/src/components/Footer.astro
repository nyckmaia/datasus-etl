---
import type { Locale } from '~/lib/i18n';
import { VERSION, releasesIndexUrl, repoUrl, issuesUrl } from '~/lib/releases';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

const COPY = {
  en: {
    build: 'Build',
    version: 'Version',
    license: 'License',
    source: 'Source',
    pkgSource: 'VERSION file',
    navigation: 'Navigation',
    legal: 'Legal',
    linksRepo: 'Repository',
    linksReleases: 'Releases',
    linksIssues: 'Issues',
    disclaim:
      'DataSUS is a registered trademark of the Brazilian Ministry of Health. This project is an independent open-source tool and is not affiliated with DATASUS or the Ministry of Health.',
    stack: 'Built with Astro, Tailwind, IBM Plex Sans, JetBrains Mono. No trackers; the only local storage entry is your language and theme preference.',
  },
  pt: {
    build: 'Build',
    version: 'Versão',
    license: 'Licença',
    source: 'Fonte',
    pkgSource: 'arquivo VERSION',
    navigation: 'Navegação',
    legal: 'Legal',
    linksRepo: 'Repositório',
    linksReleases: 'Releases',
    linksIssues: 'Issues',
    disclaim:
      'DATASUS é uma marca registrada do Ministério da Saúde do Brasil. Este é um projeto independente, de código aberto, sem vínculo com o DATASUS ou com o Ministério da Saúde.',
    stack: 'Construído com Astro, Tailwind, IBM Plex Sans, JetBrains Mono. Sem rastreadores; o único dado local é sua preferência de idioma e tema.',
  },
} as const;

const t = COPY[locale];
---

<footer class="mt-24 border-t border-border bg-surface">
  <div class="max-w-7xl mx-auto px-6 md:px-10 py-12">
    <div class="grid md:grid-cols-[1.6fr_1fr_1fr] gap-10">
      <div>
        <div class="label-stamp-strong">{t.build}</div>
        <dl class="mt-4 grid grid-cols-[auto_1fr] gap-x-5 gap-y-2 text-sm">
          <dt class="label-stamp pt-0.5">{t.version}</dt>
          <dd class="mono-val">v{VERSION}</dd>
          <dt class="label-stamp pt-0.5">{t.license}</dt>
          <dd class="mono-val">GPL-3.0</dd>
          <dt class="label-stamp pt-0.5">{t.source}</dt>
          <dd class="mono-val text-[0.9rem]">{t.pkgSource}</dd>
        </dl>
        <p class="mt-5 max-w-md text-xs text-muted leading-relaxed">{t.stack}</p>
      </div>

      <div>
        <div class="label-stamp-strong">{t.navigation}</div>
        <ul class="mt-4 space-y-2 text-sm">
          <li><a href={repoUrl()} rel="noopener noreferrer" target="_blank" class="text-muted hover:text-brand transition-colors">{t.linksRepo} ↗</a></li>
          <li><a href={releasesIndexUrl()} rel="noopener noreferrer" target="_blank" class="text-muted hover:text-brand transition-colors">{t.linksReleases} ↗</a></li>
          <li><a href={issuesUrl()} rel="noopener noreferrer" target="_blank" class="text-muted hover:text-brand transition-colors">{t.linksIssues} ↗</a></li>
        </ul>
      </div>

      <div>
        <div class="label-stamp-strong">{t.legal}</div>
        <p class="mt-4 text-xs text-muted leading-relaxed">{t.disclaim}</p>
        <p class="mt-4 text-xs text-muted">© {new Date().getFullYear()}</p>
      </div>
    </div>
  </div>
</footer>
