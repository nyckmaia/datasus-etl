---
import { PLATFORMS, downloadUrl, VERSION } from '~/lib/releases';
import type { Locale } from '~/lib/i18n';

interface Props {
  locale: Locale;
  variant?: 'hero' | 'inline';
}

const { locale, variant = 'hero' } = Astro.props;
const fallback = PLATFORMS[0]; // Windows as safe default
const fallbackUrl = downloadUrl(fallback);
// Serialized once at build time and embedded directly on the widget as a
// data- attribute. Using a separate <script type="application/json"> tag
// breaks in Astro because expressions inside <script> are treated as
// opaque text, not evaluated.
const platformsJson = JSON.stringify(
  PLATFORMS.map((p) => ({ id: p.id, ext: p.extension, label: p.label })),
);

const copy = {
  en: {
    download: 'Download',
    for: 'for',
    version: 'Version',
    detecting: 'detecting your platform…',
    other: 'other platforms',
  },
  pt: {
    download: 'Baixar',
    for: 'para',
    version: 'Versão',
    detecting: 'detectando sua plataforma…',
    other: 'outras plataformas',
  },
}[locale];
---

<div
  class:list={[
    'download-widget group',
    variant === 'hero' ? 'block' : 'inline-flex items-center gap-3',
  ]}
  data-version={VERSION}
  data-platforms={platformsJson}
>
  <a
    href={fallbackUrl}
    data-download-link
    class:list={[
      'dl-button group/btn inline-flex items-center gap-3 font-medium transition-all',
      'border border-brand bg-brand text-bg hover:bg-brand-hover hover:border-brand-hover',
      variant === 'hero' ? 'px-5 py-3 text-[0.95rem] rounded' : 'px-3.5 py-2 text-sm rounded',
    ]}
  >
    <svg
      class="w-4 h-4 flex-shrink-0 transition-transform group-hover/btn:translate-y-0.5"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M12 3v12"></path>
      <path d="M7 10l5 5 5-5"></path>
      <path d="M4 20h16"></path>
    </svg>
    <span data-slot="cta">{copy.download}</span>
    <span class="h-4 w-px bg-bg/30" aria-hidden="true"></span>
    <span class="font-mono text-sm leading-none" data-slot="platform">
      {copy.detecting}
    </span>
  </a>

  {variant === 'hero' && (
    <div class="mt-3 flex flex-wrap items-baseline gap-x-3 gap-y-1 text-sm">
      <span class="label-stamp">{copy.version}</span>
      <span class="mono-val">v{VERSION}</span>
      <span class="text-muted/50" aria-hidden="true">·</span>
      <a
        href={Astro.url.pathname.includes('/pt/') ? '../download/' : './download/'}
        class="text-muted hover:text-brand border-b border-muted/30 hover:border-brand transition-colors"
        data-slot="other-link"
      >{copy.other} →</a>
    </div>
  )}
</div>

<script>
  interface AssetData { id: string; ext: string; label: string }

  type DetectResult =
    | { kind: 'asset'; asset: AssetData }
    | { kind: 'intel-mac' };

  function detect(data: AssetData[]): DetectResult {
    if (typeof navigator === 'undefined') return { kind: 'asset', asset: data[0] };
    const ua = (navigator.userAgent || '').toLowerCase();
    const platform = (
      (navigator as Navigator & { userAgentData?: { platform?: string } })
        .userAgentData?.platform ?? ''
    ).toLowerCase();

    const isMac = platform.includes('mac') || ua.includes('mac os') || ua.includes('macintosh');
    const isWin = platform.includes('win') || ua.includes('windows');
    const isLin = platform.includes('linux') || ua.includes('linux');

    if (isMac) {
      // Apple Silicon sniff — imperfect but good enough for a suggestion.
      const arm =
        ua.includes('arm64') ||
        ua.includes('apple silicon') ||
        (navigator as Navigator & { userAgentData?: { architecture?: string } })
          .userAgentData?.architecture?.includes('arm');
      if (arm) {
        const asset = data.find((p) => p.id === 'macos-arm64');
        if (asset) return { kind: 'asset', asset };
      }
      // Intel Mac (or unclear arch on Mac) — we don't ship a native installer.
      return { kind: 'intel-mac' };
    }
    if (isLin) {
      const asset = data.find((p) => p.id === 'linux-x64');
      if (asset) return { kind: 'asset', asset };
    }
    if (isWin) {
      const asset = data.find((p) => p.id === 'windows-x64');
      if (asset) return { kind: 'asset', asset };
    }
    return { kind: 'asset', asset: data[0] };
  }

  const widgets = document.querySelectorAll<HTMLElement>('.download-widget');
  widgets.forEach((w) => {
    const raw = w.dataset.platforms ?? '[]';
    let data: AssetData[] = [];
    try {
      data = JSON.parse(raw);
    } catch (err) {
      console.warn('[DownloadButton] could not parse platforms data', err);
      return;
    }
    const result = detect(data);
    const version = w.dataset.version ?? '';
    const link = w.querySelector<HTMLAnchorElement>('[data-download-link]');
    const slot = w.querySelector<HTMLElement>('[data-slot="platform"]');
    const cta = w.querySelector<HTMLElement>('[data-slot="cta"]');

    if (result.kind === 'intel-mac') {
      // Route Intel Mac users to the source-install walkthrough.
      const isPt = window.location.pathname.includes('/pt/');
      const target = isPt ? '/datasus-etl/pt/download/#intel-mac' : '/datasus-etl/download/#intel-mac';
      if (link) link.href = target;
      if (slot) slot.textContent = isPt ? 'Mac Intel — instalar do código' : 'Intel Mac — install from source';
      if (cta) cta.textContent = isPt ? 'Instruções' : 'Instructions';
      return;
    }

    const chosen = result.asset;
    const filename = `datasus-etl-${version}-${chosen.id}.${chosen.ext}`;
    const url = `https://github.com/nyckmaia/datasus-etl/releases/download/v${version}/${filename}`;
    if (link) link.href = url;
    if (slot) slot.textContent = chosen.label;
  });
</script>
