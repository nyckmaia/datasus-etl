---
interface Props {
  index: string;        // "01", "02", ...
  title: string;
  body: string;
  icon: 'download' | 'transform' | 'enrich' | 'serve';
  status?: string;      // optional pill label, e.g. "Stable", "Beta"
}

const { index, title, body, icon, status } = Astro.props;
---

<article class="card p-6 md:p-7 relative overflow-hidden">
  <div class="flex items-start justify-between gap-4">
    <div class="flex items-center gap-3">
      <span
        class="mono-val text-xs text-brand border border-brand/30 bg-brand/10 px-1.5 py-0.5 rounded"
      >{index}</span>
      <div class="flex items-center justify-center w-9 h-9 bg-surface-2 border border-border rounded text-brand">
        {icon === 'download' && (
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 3v12"></path>
            <path d="M7 10l5 5 5-5"></path>
            <path d="M4 20h16"></path>
          </svg>
        )}
        {icon === 'transform' && (
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M4 7h11"></path>
            <path d="M15 3l4 4-4 4"></path>
            <path d="M20 17H9"></path>
            <path d="M9 13l-4 4 4 4"></path>
          </svg>
        )}
        {icon === 'enrich' && (
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="8"></circle>
            <path d="M12 4v16"></path>
            <path d="M4 12h16"></path>
            <path d="M6.34 6.34l11.32 11.32"></path>
          </svg>
        )}
        {icon === 'serve' && (
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="4" width="18" height="6" rx="1"></rect>
            <rect x="3" y="14" width="18" height="6" rx="1"></rect>
            <circle cx="7" cy="7" r="0.6" fill="currentColor"></circle>
            <circle cx="7" cy="17" r="0.6" fill="currentColor"></circle>
          </svg>
        )}
      </div>
    </div>
    {status && (
      <span class="pill pill-brand">
        <span class="pill-dot"></span>
        {status}
      </span>
    )}
  </div>

  <h3 class="mt-5 text-display text-text font-semibold">{title}</h3>
  <p class="mt-2 text-[0.94rem] leading-relaxed text-muted max-w-prose-tech">
    {body}
  </p>
</article>
