---
import '~/styles/global.css';
import TopBar from '~/components/TopBar.astro';
import Footer from '~/components/Footer.astro';
import type { Locale } from '~/lib/i18n';

interface Props {
  title: string;
  description?: string;
  locale: Locale;
  currentKey?: string;
  ptPath?: string; // path (without /pt/ prefix) to the PT version of the current page
}

const { title, description, locale, currentKey, ptPath } = Astro.props;
const base = import.meta.env.BASE_URL;
const canonicalRel = Astro.url.pathname;
---

<!doctype html>
<html lang={locale === 'pt' ? 'pt-BR' : 'en'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · DataSUS ETL</title>
    {description && <meta name="description" content={description} />}
    <meta name="color-scheme" content="light" />
    <meta name="theme-color" content="#f3ece0" />
    <link rel="icon" href={`${base}/favicon.svg`} type="image/svg+xml" />
    <link rel="canonical" href={`https://nyckmaia.github.io${canonicalRel}`} />

    <!--
      First-visit redirect. Runs before paint so we don't flash the EN
      version to a PT-speaking visitor. Only active on the EN default
      pages; if the user already has a stored preference, respect it.
    -->
    <script is:inline set:html={`
      (function() {
        try {
          var stored = localStorage.getItem('lang');
          var path = window.location.pathname;
          var isEn = path.indexOf('${base}/pt/') !== 0 && path.indexOf('/pt/') !== 0;
          if (stored === 'pt' && isEn && ${JSON.stringify(Boolean(ptPath))}) {
            var target = '${base}/pt${ptPath ?? ''}'.replace(/\\/+/g, '/');
            if (!/\\/$/.test(target) && !/\\.[a-z]+$/.test(target)) target += '/';
            window.location.replace(target);
            return;
          }
          if (!stored) {
            var lang = (navigator.language || 'en').toLowerCase();
            if (lang.indexOf('pt') === 0 && isEn && ${JSON.stringify(Boolean(ptPath))}) {
              localStorage.setItem('lang', 'pt');
              var target2 = '${base}/pt${ptPath ?? ''}'.replace(/\\/+/g, '/');
              if (!/\\/$/.test(target2) && !/\\.[a-z]+$/.test(target2)) target2 += '/';
              window.location.replace(target2);
            }
          }
        } catch (e) { /* no-op */ }
      })();
    `} />
  </head>
  <body class="antialiased">
    <TopBar locale={locale} currentKey={currentKey} ptPath={ptPath} />
    <main class="relative">
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
