---
import '~/styles/global.css';
import TopBar from '~/components/TopBar.astro';
import Footer from '~/components/Footer.astro';
import type { Locale } from '~/lib/i18n';

interface Props {
  title: string;
  description?: string;
  locale: Locale;
  currentKey?: string;
  ptPath?: string; // path (without /pt/ prefix) to the PT version of the current page
  ogImage?: string; // filename inside /assets/, default brand-small
}

const SITE_URL = 'https://datasus-etl.com.br';
const DEFAULT_OG_IMAGE = 'DataSUS-ETL - Brand-small.png';

const { title, description, locale, currentKey, ptPath, ogImage = DEFAULT_OG_IMAGE } = Astro.props;
const base = import.meta.env.BASE_URL;
const canonicalRel = Astro.url.pathname;
const fullTitle = `${title} · DataSUS ETL`;
const ogImageUrl = `${SITE_URL}${encodeURI(`/assets/${ogImage}`)}`;
---

<!doctype html>
<html lang={locale === 'pt' ? 'pt-BR' : 'en'} class="theme-dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    <meta name="color-scheme" content="dark light" />
    <meta name="theme-color" content="#0b1220" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#fafbfc" media="(prefers-color-scheme: light)" />
    <link rel="icon" href={`${base}/favicon.svg`} type="image/svg+xml" />
    <link rel="canonical" href={`${SITE_URL}${canonicalRel}`} />

    <!-- Open Graph (WhatsApp/Facebook/LinkedIn link previews) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="DataSUS ETL" />
    <meta property="og:title" content={fullTitle} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={`${SITE_URL}${canonicalRel}`} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content="DataSUS ETL logo" />
    <meta property="og:locale" content={locale === 'pt' ? 'pt_BR' : 'en_US'} />

    <!-- Twitter Card (also consumed by X, LinkedIn, Slack) -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImageUrl} />

    <!--
      Anti-FOUC: read persisted theme (or fall back to dark) before the first
      paint. This runs synchronously in the <head>, so the correct .theme-*
      class is on <html> before any CSS is applied.
    -->
    <script is:inline set:html={`
      (function() {
        try {
          var stored = localStorage.getItem('theme');
          var root = document.documentElement;
          root.classList.remove('theme-dark', 'theme-light');
          root.classList.add(stored === 'light' ? 'theme-light' : 'theme-dark');
        } catch (e) {
          /* private mode — keep default theme-dark already on the html tag */
        }
      })();
    `} />

    <!--
      First-visit i18n redirect. Runs before paint so we don't flash the EN
      version to a PT-speaking visitor. Only redirects if a PT version of
      this specific page exists (ptPath prop is truthy).
    -->
    <script is:inline set:html={`
      (function() {
        try {
          var stored = localStorage.getItem('lang');
          var path = window.location.pathname;
          var isEn = path.indexOf('${base}/pt/') !== 0 && path.indexOf('/pt/') !== 0;
          if (stored === 'pt' && isEn && ${JSON.stringify(Boolean(ptPath))}) {
            var target = '${base}/pt${ptPath ?? ''}'.replace(/\\/+/g, '/');
            if (!/\\/$/.test(target) && !/\\.[a-z]+$/.test(target)) target += '/';
            window.location.replace(target);
            return;
          }
          if (!stored) {
            var lang = (navigator.language || 'en').toLowerCase();
            if (lang.indexOf('pt') === 0 && isEn && ${JSON.stringify(Boolean(ptPath))}) {
              localStorage.setItem('lang', 'pt');
              var target2 = '${base}/pt${ptPath ?? ''}'.replace(/\\/+/g, '/');
              if (!/\\/$/.test(target2) && !/\\.[a-z]+$/.test(target2)) target2 += '/';
              window.location.replace(target2);
            }
          }
        } catch (e) { /* no-op */ }
      })();
    `} />
  </head>
  <body class="antialiased text-text">
    <TopBar locale={locale} currentKey={currentKey} ptPath={ptPath} />
    <main class="relative">
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
